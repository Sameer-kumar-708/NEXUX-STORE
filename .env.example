# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/nexus-store

# Secret for signing auth cookies (use a long random string, min 16 chars)
JWT_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# Admin access: /admin is only for users with role "admin" in the users collection.
# Set in MongoDB, e.g. db.users.updateOne({ email: "you@example.com" }, { $set: { role: "admin" } })
# Then sign out and sign in again so the JWT includes the new role.
